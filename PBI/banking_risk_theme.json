{
  "name": "Banking Risk Executive Theme",
  "dataColors": [
    "#2563EB",
    "#1E3A8A",
    "#F59E0B",
    "#DC2626",
    "#10B981",
    "#64748B"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E2E8F0" } },
            "radius": 10
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#CBD5E1" } },
            "transparency": 70,
            "blur": 8,
            "angle": 45,
            "distance": 2
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#64748B" } },
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 10
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#334155" } },
            "textSize": 9
          }
        ]
      }
    }
  }
}